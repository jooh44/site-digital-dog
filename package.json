{
  "name": "site-digital-dog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "outbound:oab-search": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-oab-registry-search.ts",
    "outbound:bulk-discovery": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-bulk-lead-discovery.ts",
    "outbound:cnsa-search": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-cnsa-registry-search.ts",
    "outbound:official-site": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-official-site-enrichment.ts",
    "outbound:web-search": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-google-web-search-enrichment.ts",
    "outbound:codex-fallback": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-codex-fallback-enrichment.ts",
    "outbound:auto-capture": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-auto-capture-cycle.ts",
    "outbound:auto-capture-daemon": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-auto-capture-daemon.ts --mode=auto-capture",
    "outbound:auto-capture-loop": "scripts/outbound/run-auto-capture-loop.sh",
    "outbound:shortlist": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/export-search-shortlist.ts",
    "outbound:sync-email-state": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/sync-resend-email-state.ts",
    "outbound:prepare-email": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/prepare-email-campaign.ts",
    "outbound:slot-scheduler": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-slot-scheduler.ts",
    "outbound:prepare-followup": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/prepare-followup-email-campaign.ts",
    "outbound:refresh-scheduled-copy": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/refresh-scheduled-email-copy.ts",
    "outbound:backup-db": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/backup-database.ts",
    "outbound:health": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/check-health.ts",
    "outbound:start": "pm2 start ecosystem.config.cjs",
    "outbound:stop": "pm2 stop ecosystem.config.cjs",
    "outbound:logs": "pm2 logs lead-engine-auto-capture lead-engine-gemini-email lead-engine-slot-scheduler",
    "outbound:followup-cycle": "scripts/outbound/run-followup-cycle.sh",
    "outbound:schedule-email": "node --experimental-strip-types --experimental-default-type=module scripts/outbound/schedule-email-campaign.ts",
    "outbound:stop-services": "scripts/outbound/stop-outbound-services.sh",
    "outbound:gemini-email": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-gemini-email-enricher.ts",
    "outbound:gemini-email-premium": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-gemini-email-enricher.ts --premium --limit=3 --dailyLimit=5 --timeoutMs=120000",
    "outbound:ig-whatsapp": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/run-instagram-whatsapp-enricher.ts",
    "outbound:gemini-email-loop": "while true; do npm run outbound:gemini-email; echo 'Sleeping 30s...'; sleep 30; done",
    "outbound:slot-scheduler-loop": "while true; do npm run outbound:sync-email-state; npm run outbound:slot-scheduler; echo 'Sleeping 60s...'; sleep 60; done",
    "outbound:export-social-selling": "node --env-file=.env.local --experimental-strip-types --experimental-default-type=module scripts/outbound/export-social-selling-leads.ts"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.0.3",
    "@studio-freight/react-lenis": "^0.0.47",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lucide-react": "^0.554.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "playwright": "^1.59.1",
    "pm2": "^6.0.14",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
