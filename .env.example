# =============================================================================
# Variáveis de Ambiente — Digital Dog
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite .env.local no repositório
# =============================================================================

# ─── Email de Notificação (Resend) ─────────────────────────────────────────
# Chave de API do Resend (server-only — jamais use prefixo NEXT_PUBLIC_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remetente configurado no painel Resend (deve estar verificado)
RESEND_FROM_EMAIL=noreply@digitaldog.com.br

# Email que receberá as notificações de novos leads
NOTIFICATION_EMAIL=johny@digitaldog.com.br

# ─── Analytics (Client-safe) ───────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_MESSAGE=
